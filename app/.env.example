# Nubuat — Environment Variables
#
# ATURAN: hanya 3 variabel WAJIB. Sisanya di database (lihat AGENTS.md §4).
# Bootstrap secret env (BOOTSTRAP_*) bersifat OPSIONAL & one-shot — set saat seed
# pertama, lalu hapus karena nilai sudah aman di DB (terenkripsi AES-256-GCM).
#
# Generate APP_MASTER_KEY dengan: npm run generate:key
#
# Catatan keamanan:
#   - JANGAN commit file .env asli ke git
#   - Produksi: pakai secret manager (AWS Secrets Manager / GCP / Vault)

# ===== WAJIB =====

# Koneksi PostgreSQL (sudah include TimescaleDB & pgvector extension)
DATABASE_URL=postgresql://nubuat:nubuat@localhost:5432/nubuat

# Koneksi Redis (untuk session, cache, BullMQ)
REDIS_URL=redis://localhost:6379

# Master encryption key — 64 hex char (32 byte). WAJIB di-generate ulang per environment.
# Digunakan untuk enkripsi nilai di tabel app_secrets (AES-256-GCM).
APP_MASTER_KEY=replace_with_64_hex_chars_run_npm_run_generate_key

# ===== OPSIONAL =====

# Email admin pertama yang otomatis dipromote ke role=admin saat signup.
ADMIN_BOOTSTRAP_EMAIL=admin@nubuat.local

# ===== ONE-SHOT BOOTSTRAP SECRETS (HAPUS SETELAH SEED PERTAMA) =====
#
# Saat `npm run db:seed` dijalankan, nilai-nilai di bawah ini akan dienkripsi
# dengan APP_MASTER_KEY dan disimpan ke tabel `app_secrets`. Setelah itu, HAPUS
# baris-baris ini dari .env Anda — nilai sudah aman di DB.
#
# Catatan: bootstrap akan SELALU MENG-OVERWRITE nilai existing di DB. Jadi
# jangan biarkan terisi di runtime normal — hanya saat rotation/setup.

# DeepSeek (AI Copilot — provider default)
# BOOTSTRAP_AI_DEEPSEEK_API_KEY=sk-xxxx

# Anthropic (fallback kalau swap provider)
# BOOTSTRAP_AI_ANTHROPIC_API_KEY=sk-ant-xxxx

# OpenAI (fallback kalau swap provider)
# BOOTSTRAP_AI_OPENAI_API_KEY=sk-xxxx

# Vendor data
# BOOTSTRAP_VENDOR_INVEZGO_API_KEY=
# BOOTSTRAP_VENDOR_OHLC_DEV_API_KEY=
# BOOTSTRAP_VENDOR_ITICK_API_KEY=

# Payment gateway
# BOOTSTRAP_PAYMENT_MIDTRANS_SERVER_KEY=
# BOOTSTRAP_PAYMENT_MIDTRANS_CLIENT_KEY=
# BOOTSTRAP_PAYMENT_XENDIT_API_KEY=

# SMTP
# BOOTSTRAP_SMTP_PASSWORD=
