{
  "name": "nubuat",
  "version": "1.7.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "NODE_ENV=production next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "lhci": "lhci autorun --config=./.lighthouserc.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env db/seed/index.ts",
    "db:fetch-emiten": "tsx --env-file=.env scripts/fetch-emiten.ts",
    "db:seed-demo": "tsx --env-file=.env scripts/seed-demo-users.ts",
    "db:enrich": "tsx --env-file=.env scripts/enrich-companies.ts",
    "logos:sync": "tsx --env-file=.env scripts/sync-logos.ts",
    "post-deploy": "tsx --env-file=.env scripts/post-deploy.ts",
    "db:seed-research": "tsx --env-file=.env db/seed/research-sample.ts",
    "db:embed-research": "tsx --env-file=.env scripts/embed-research.ts",
    "worker": "tsx --env-file=.env worker/index.ts",
    "worker:prod": "tsx worker/index.ts",
    "test": "vitest",
    "test:e2e": "playwright test",
    "generate:key": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "prepare": "husky"
  },
  "dependencies": {
