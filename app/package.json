    "drizzle-zod": "^0.6.0",
    "ioredis": "^5.4.1",
    "lightweight-charts": "^4.2.0",
    "lucide-react": "^0.469.0",
    "next": "15.1.11",
    "next-intl": "^3.26.0",
    "nuqs": "^2.2.0",
    "openai": "^4.77.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
